---
import { getLandingData } from "../../lib/data";

const landing = await getLandingData();
const { about } = landing;
---

<section id="about" class="py-16 bg-white">
  <div class="container mx-auto px-4">
    <div class="text-center mb-12">
      <h2 class="text-3xl font-bold text-gray-900 mb-4">{about.title}</h2>
      {
        about.subtitle && (
          <p class="text-xl text-gray-600 max-w-2xl mx-auto">
            {about.subtitle}
          </p>
        )
      }
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 items-start">
      {/* Contact Info */}
      <div class="bg-gray-50 rounded-2xl p-8 shadow-sm h-full">
        <div class="space-y-8">
          {/* Where we are */}
          <div>
            <h3 class="text-xl font-semibold text-gray-900 mb-4">
              Где находимся
            </h3>
            <div class="flex items-start gap-3">
              <svg
                xmlns="http://www.w3.org/2000/svg"
                class="h-6 w-6 text-indigo-600 mt-1 shrink-0"
                fill="none"
                viewBox="0 0 24 24"
                stroke="currentColor"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"
                ></path>
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path>
              </svg>
              <div>
                <p class="text-gray-600 font-medium">
                  Адрес офиса (юридический)
                </p>
                <p class="text-gray-900 text-lg">{about.address}</p>
              </div>
            </div>
          </div>

          {/* How to contact */}
          <div>
            <h3 class="text-xl font-semibold text-gray-900 mb-4">
              Как связаться
            </h3>
            <div class="space-y-4">
              <div class="flex items-start gap-3">
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  class="h-6 w-6 text-indigo-600 mt-1 shrink-0"
                  fill="none"
                  viewBox="0 0 24 24"
                  stroke="currentColor"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"
                  ></path>
                </svg>
                <div>
                  <p class="text-gray-600 font-medium">Телефон</p>
                  <a
                    href={`tel:${about.phone.replace(/[^\d+]/g, "")}`}
                    class="text-gray-900 text-lg hover:text-indigo-600 transition-colors"
                  >
                    {about.phone}
                  </a>
                </div>
              </div>
              <div class="flex items-start gap-3">
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  class="h-6 w-6 text-indigo-600 mt-1 shrink-0"
                  fill="none"
                  viewBox="0 0 24 24"
                  stroke="currentColor"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"
                  ></path>
                </svg>
                <div>
                  <p class="text-gray-600 font-medium">Email для связи</p>
                  <a
                    href={`mailto:${about.email}`}
                    class="text-gray-900 text-lg hover:text-indigo-600 transition-colors"
                  >
                    {about.email}
                  </a>
                </div>
              </div>
            </div>
          </div>

          {/* When we work */}
          <div>
            <h3 class="text-xl font-semibold text-gray-900 mb-4">
              Когда работаем
            </h3>
            <div class="flex items-start gap-3">
              <svg
                xmlns="http://www.w3.org/2000/svg"
                class="h-6 w-6 text-indigo-600 mt-1 shrink-0"
                fill="none"
                viewBox="0 0 24 24"
                stroke="currentColor"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path>
              </svg>
              <div>
                <p class="text-gray-600 font-medium">График работы</p>
                <p class="text-gray-900 text-lg">{about.workingHours}</p>
              </div>
            </div>
          </div>
        </div>
      </div>

      {/* Map */}
      <div
        class="h-full min-h-[400px] rounded-2xl overflow-hidden shadow-sm border border-gray-100 relative"
      >
        <!-- <iframe
          src={about.mapEmbedUrl}
          width="100%"
          height="100%"
          allowfullscreen="true"
          style="position:absolute; top:0; left:0; width:100%; height:100%; border:0;"
          loading="lazy"
          title="Office Location"></iframe> -->
        <a
          href="https://yandex.ru/maps/213/moscow/?utm_medium=mapframe&utm_source=maps"
          style="color:#eee;font-size:12px;position:absolute;top:0px;"
        >
          Москва
        </a>
        <a
          href="https://yandex.ru/maps/213/moscow/house/ulitsa_izmaylovskiy_val_30/Z04YcQZoSkwOQFtvfXt5dn1ibA==/?ll=37.718399%2C55.787118&utm_medium=mapframe&utm_source=maps&z=17.23"
          style="color:#eee;font-size:12px;position:absolute;top:14px;"
        >
          Улица Измайловский Вал, 30 — Яндекс Карты
        </a>
        <iframe
          src="https://yandex.ru/map-widget/v1/?ll=37.718399%2C55.787118&mode=search&ol=geo&ouri=ymapsbm1%3A%2F%2Fgeo%3Fdata%3DCgg1Njc0MjMxMBJK0KDQvtGB0YHQuNGPLCDQnNC-0YHQutCy0LAsINGD0LvQuNGG0LAg0JjQt9C80LDQudC70L7QstGB0LrQuNC5INCS0LDQuywgMzAiCg2l3xZCFQImX0I%2C&z=17.23"
          width="100%"
          height="100%"
          allowfullscreen="true"
          style="position:absolute; top:0; left:0; width:100%; height:100%; border:0;"
          loading="lazy"
          title="Office Location"></iframe>
      </div>
    </div>
  </div>
</section>
