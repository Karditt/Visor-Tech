---
import { getLandingData } from "../../lib/data";
import { Image } from "astro:assets";
import bgImage from "../../assets/images/background.png";

const landing = await getLandingData();
const { hero } = landing;
---

<section
  id="hero"
  class="relative bg-brand-dark min-h-screen flex items-center pt-20 pb-16 overflow-hidden"
>
  <!-- Background Image with Astro Optimization -->
  <div class="absolute inset-0 z-0 bg-[#0A0F1A]">
    <!-- Added a dark background color behind the image in case it doesn't cover everything -->
    <Image
      src={bgImage}
      alt="Hero Background"
      class="w-full h-full object-cover object-center translate-x-[15%] md:translate-x-0 opacity-100 mix-blend-screen"
      loading="eager"
      fetchpriority="high"
    />
  </div>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative">
    <div
      class="inline-block relative z-10 p-6 md:p-10 rounded-3xl bg-white/70 backdrop-blur-md shadow-2xl border border-white/40 max-w-2xl lg:max-w-3xl"
    >
      <h1
        class="text-4xl md:text-5xl lg:text-6xl font-extrabold text-brand-dark leading-tight mb-6 drop-shadow-sm"
      >
        {hero.title}
      </h1>

      <p class="text-lg md:text-xl text-gray-800 mb-8 max-w-2xl font-medium">
        {hero.subtitle}
      </p>

      <div class="flex flex-col sm:flex-row gap-4 mb-10">
        {
          hero.benefits.map((benefit) => (
            <div class="flex items-center text-brand-dark font-bold bg-white/50 px-3 py-1.5 rounded-lg border border-white/40">
              <svg
                class="w-5 h-5 text-brand-primary mr-2 drop-shadow-sm"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
                xmlns="http://www.w3.org/2000/svg"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M5 13l4 4L19 7"
                />
              </svg>
              {benefit}
            </div>
          ))
        }
      </div>

      <a
        href="#contacts"
        class="inline-flex items-center justify-center px-8 py-3 text-base font-semibold text-white bg-brand-accent hover:bg-red-700 transition-all rounded-lg shadow-md hover:shadow-lg transform hover:-translate-y-0.5"
      >
        {hero.ctaButton}
      </a>
    </div>
  </div>
</section>
