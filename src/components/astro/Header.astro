---
import { getLandingData } from "../../lib/data";
import logo from "../../assets/icons/logo.svg";
import { Image } from "astro:assets";

const landing = await getLandingData();
const { header } = landing;
---

<header
  id="header"
  class="fixed top-0 left-0 right-0 z-50 bg-white/95 backdrop-blur-sm border-b border-gray-100 transition-all duration-300 max-w-[100vw]"
>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex justify-between items-center h-20">
      <!-- Logo -->
      <div class="flex-shrink-0 flex items-center">
        <a
          href="/"
          aria-label="vizortex Contacts"
          class="hover:opacity-80 transition-opacity"
        >
          <Image src={logo} alt="vizortex" class="h-12 w-auto" />
        </a>
      </div>

      <!-- Desktop Navigation -->
      <nav class="hidden md:flex space-x-8">
        {
          header.nav.map((item) => (
            <a
              href={item.href}
              class="text-gray-600 hover:text-gray-900 font-medium transition-colors"
            >
              {item.label}
            </a>
          ))
        }
      </nav>

      <!-- Desktop Actions -->
      <div class="hidden md:flex items-center space-x-6">
        <a
          href={header.phoneHref}
          class="text-gray-600 hover:text-gray-900 font-medium transition-colors"
        >
          {header.phone}
        </a>
        <a
          href="#contacts"
          class="inline-flex items-center justify-center px-5 py-2.5 border border-transparent rounded-lg text-sm font-medium text-white bg-gray-900 hover:bg-gray-800 transition-all shadow-sm hover:shadow-md"
        >
          {header.ctaButton}
        </a>
      </div>

      <!-- Mobile menu button -->
      <div class="flex items-center md:hidden">
        <a
          href={header.phoneHref}
          class="mr-4 text-gray-600 hover:text-gray-900"
        >
          <!-- Phone Icon -->
          <svg
            xmlns="http://www.w3.org/2000/svg"
            fill="none"
            viewBox="0 0 24 24"
            stroke-width="1.5"
            stroke="currentColor"
            class="w-6 h-6"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 0 0 2.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 0 1-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 0 0-1.091-.852H4.5A2.25 2.25 0 0 0 2.25 4.5v2.25Z"
            ></path>
          </svg>
        </a>
        <button
          id="mobile-menu-btn"
          type="button"
          class="inline-flex items-center justify-center p-2 rounded-md text-gray-500 hover:text-gray-900 hover:bg-gray-100 focus:outline-none focus:ring-2 focus:ring-inset focus:ring-gray-500"
          aria-controls="mobile-menu"
          aria-expanded="false"
        >
          <span class="sr-only">Open main menu</span>
          <!-- Icon when menu is closed -->
          <svg
            id="menu-icon-closed"
            class="block h-6 w-6"
            xmlns="http://www.w3.org/2000/svg"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
            aria-hidden="true"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M4 6h16M4 12h16M4 18h16"></path>
          </svg>
          <!-- Icon when menu is open -->
          <svg
            id="menu-icon-open"
            class="hidden h-6 w-6"
            xmlns="http://www.w3.org/2000/svg"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
            aria-hidden="true"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M6 18L18 6M6 6l12 12"></path>
          </svg>
        </button>
      </div>
    </div>
  </div>

  <!-- Mobile menu, show/hide based on menu state. -->
  <div
    class="md:hidden hidden bg-white border-t border-gray-100 absolute left-0 right-0"
    id="mobile-menu"
  >
    <div class="px-4 pt-2 pb-6 space-y-2 shadow-lg">
      {
        header.nav.map((item) => (
          <a
            href={item.href}
            class="mobile-link block px-3 py-3 rounded-md text-base font-medium text-gray-700 hover:text-gray-900 hover:bg-gray-50"
          >
            {item.label}
          </a>
        ))
      }

      <div class="mt-6 pt-6 border-t border-gray-100 flex flex-col gap-4">
        <a
          href={header.phoneHref}
          class="block px-3 text-base font-semibold text-gray-900"
        >
          {header.phone}
        </a>
        <a
          href="#contacts"
          class="mobile-link w-full flex items-center justify-center px-4 py-3 border border-transparent rounded-lg shadow-sm text-base font-medium text-white bg-gray-900 hover:bg-gray-800"
        >
          {header.ctaButton}
        </a>
      </div>
    </div>
  </div>
</header>

<script>
  const btn = document.getElementById("mobile-menu-btn");
  const menu = document.getElementById("mobile-menu");
  const iconClosed = document.getElementById("menu-icon-closed");
  const iconOpen = document.getElementById("menu-icon-open");
  const mobileLinks = document.querySelectorAll(".mobile-link");

  if (btn && menu && iconClosed && iconOpen) {
    btn.addEventListener("click", () => {
      const isExpanded = btn.getAttribute("aria-expanded") === "true";

      // Toggle menu visibility
      if (isExpanded) {
        menu.classList.add("hidden");
        iconClosed.classList.remove("hidden");
        iconOpen.classList.add("hidden");
      } else {
        menu.classList.remove("hidden");
        iconClosed.classList.add("hidden");
        iconOpen.classList.remove("hidden");
      }

      btn.setAttribute("aria-expanded", (!isExpanded).toString());
    });

    // Close menu when clicking a link
    mobileLinks.forEach((link) => {
      link.addEventListener("click", () => {
        menu.classList.add("hidden");
        iconClosed.classList.remove("hidden");
        iconOpen.classList.add("hidden");
        btn.setAttribute("aria-expanded", "false");
      });
    });
  }
</script>
